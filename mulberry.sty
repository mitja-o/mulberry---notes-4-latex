% -- Query Notes --

% Creates a basic in-line query note with a margin callout mark.
%
% Arguments: 
%   (required) - query text.
%   (optional) - mark symbol, default: $\iota$, provide an empty value to skip.
%
% Examples:
%   \queryM{What is the relevance of this data?}
%   \queryM[$\star$]{What do you mean with this caption?}
%   \queryM[]{Do you think a footnote is useful?}
\newcommand{\queryM}[2][\textcircled{$\alpha$}]{
\ifthenelse{\equal{\showMulberryNotesCounter}{1}}{
    {\marginpar{{\color{mMemColor} #1}}}
    {\color{mMemColor}\textbf{MEM:} {#2}}
}% then
{}% else
}

