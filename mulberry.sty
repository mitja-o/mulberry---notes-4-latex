% Display all end-notes of quotes.
\newcommand{\queryMRenderWidget}[1]{
\ifthenelse{\equal{\showMulberryNotesCounter}{1}}{
\begin{quote}
    {\marginpar{
        {\color{mMemColor}\textcircled{$\sigma$}}
    }}
    \small
    \color{mMemColor}
    \printendnotes
\end{quote}
}% then
{}% else
}
